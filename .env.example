# ─────────────────────────────────────────────────────────────
# Pronto Satisfação — variáveis de ambiente (exemplo)
# Copie para .env e preencha. NUNCA versione o .env real.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# PostgreSQL (corresponde ao serviço "db" do docker-compose)
POSTGRES_USER=pronto
POSTGRES_PASSWORD=pronto_dev_pw
POSTGRES_DB=pronto_satisfacao
DATABASE_URL="postgresql://pronto:pronto_dev_pw@localhost:5432/pronto_satisfacao?schema=public"

# Redis (filas BullMQ + cache)
REDIS_URL="redis://localhost:6379"

# MinIO (armazenamento S3-compatível: logos, temas, exports)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_pw
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=pronto-assets
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_dev_pw

# NextAuth v5
# Gere com: openssl rand -base64 32
AUTH_SECRET=changeme-generate-a-strong-secret

# IA — Anthropic Claude API & OpenAI API for Embeddings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=

# Email (SMTP — Hostgator em produção; mailpit/local em dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Prontoclínica <nao-responda@prontoclinicafortaleza.com.br>"

# WhatsApp — Meta Cloud API (preencher quando disponível)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_SURVEY_TEMPLATE=pesquisa_satisfacao

# SMS — gateway (mock por enquanto: Zenvia/Twilio)
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER=

# Webhook Amigo Tech (HMAC-SHA256). Obrigatório em produção.
AMIGO_TECH_WEBHOOK_SECRET=

# Tenant padrão (seed)
DEFAULT_TENANT_NAME="Prontoclínica de Fortaleza"
DEFAULT_TENANT_SLUG=prontoclinica
SEED_SUPER_ADMIN_EMAIL=admin@prontoclinicafortaleza.com.br
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
